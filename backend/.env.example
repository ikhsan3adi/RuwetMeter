# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://ruwet:secret@localhost:5432/ruwetmeter

# LLM Provider Selection
ANALYSIS_PROVIDER=openrouter   # anthropic | openai | google | openrouter | deepseek | mistral | groq
CHAT_PROVIDER=openrouter       # anthropic | openai | google | openrouter | deepseek | mistral | groq
EMBEDDING_PROVIDER=openrouter  # openai | google | openrouter

# API Keys (set only those matching your provider selection)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# RSS Feeds (comma-separated)
RSS_FEED_URLS=https://news.detik.com/berita/rss,https://www.cnnindonesia.com/nasional/rss,https://www.cnbcindonesia.com/news/rss,http://rss.tempo.co/nasional,https://feed.liputan6.com/rss/news,https://www.antaranews.com/rss/top-news,https://www.sindonews.com/feed,https://www.republika.co.id/rss/nasional/

# Rate Limiting
CHAT_RATE_LIMIT_MAX=10
CHAT_RATE_LIMIT_WINDOW_MS=60000

# Data Retention (days)
DATA_RETENTION_DAYS=90
