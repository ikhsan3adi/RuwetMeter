{
  "name": "ruwetmeter-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test --preload ./tests/setup-env.ts",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/ --preload ./tests/setup-env.ts",
    "db:up": "docker compose up -d db",
    "db:init": "bun run scripts/enable-vector.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/enable-vector.ts && drizzle-kit migrate",
    "db:push": "bun run scripts/enable-vector.ts && drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@mozilla/readability": "^0.5.0",
    "drizzle-orm": "^0.40.0",
    "fast-xml-parser": "^5.9.3",
    "hono": "^4.7.0",
    "linkedom": "^0.18.0",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "prettier": "^3.9.0",
    "testcontainers": "^10.19.0",
    "typescript": "^5.7.0"
  }
}
